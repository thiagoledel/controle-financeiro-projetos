# ─── Banco de dados (PostgreSQL) ────────────────────────────────────────────────
# Usuário do banco — usado pelo docker-compose para criar o banco na primeira execução.
DB_USER=postgres

# Senha do banco — use um valor forte em produção.
DB_PASSWORD=postgres

# Nome do banco de dados a ser criado/utilizado.
DB_NAME=financial_tracker

# ─── API (apps/api) ──────────────────────────────────────────────────────────────
# URL completa de conexão com o PostgreSQL.
# Em Docker, substitua "localhost" pelo nome do serviço (ex: "db").
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_tracker

# Porta em que o servidor Express irá escutar.
PORT=3001

# Ambiente de execução: "development" | "production" | "test"
# Em "development", o TypeORM exibe as queries no console e o CORS aceita localhost:5173.
NODE_ENV=development

# ─── CORS (apenas produção) ───────────────────────────────────────────────────────
# Origem permitida para requisições cross-origin em produção.
# Em desenvolvimento este valor é ignorado — apenas localhost:5173 é aceito.
# Exemplo: https://meuapp.com
CORS_ORIGIN=
